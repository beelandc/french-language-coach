{
  "id": "pronouns-direct-object",
  "term": "Direct Object Pronouns",
  "category": "Pronouns",
  "difficulty": "intermediate",
  "definition": "Replace direct objects: me, te, le/la, nous, vous, les. Before verb.",
  "examples": [
    "Il me voit (He sees me)",
    "Je t'aime (I love you)",
    "Elle le mange (She eats it)"
  ],
  "common_pitfalls": [
    "Come BEFORE the verb",
    "me/te/le/la → m'/t'/l' before vowels"
  ],
  "related_terms": [
    "indirect-object-pronouns"
  ]
}