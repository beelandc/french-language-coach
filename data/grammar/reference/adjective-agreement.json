{
  "id": "adjective-agreement",
  "term": "Adjective Agreement",
  "category": "Adjectives",
  "difficulty": "beginner",
  "definition": "Adjectives agree in gender and number with nouns. Add -e for feminine, -s for plural.",
  "examples": [
    "Un grand arbre (masc sing)",
    "Une grande maison (fem sing)",
    "Des grands arbres (masc plur)",
    "De grandes maisons (fem plur)"
  ],
  "common_pitfalls": [
    "Add -e for feminine: grand → grande",
    "Add -s for plural: grand → grands",
    "Fem plur: grande → grandes"
  ],
  "related_terms": [
    "gender-agreement",
    "number-agreement"
  ]
}